# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Redis ─────────────────────────────────────────────────────────
# Local:  redis://localhost:6379
# Render: use the Internal Redis URL provided by Render
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────
# Your frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=20
# ── Rate Limiting ─────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=900000

# ── yt-dlp Path ───────────────────────────────────────────────────
# For Render/production with build.sh: use ./bin/yt-dlp
# For local development: leave empty if yt-dlp is in system PATH
YTDLP_PATH=./bin/yt-dlp

# ── YouTube Authentication ───────────────────────────────────────
# YouTube now requires authentication to bypass bot detection.
# 
# Option 1: Export cookies from logged-in browser
#   - Use "Get cookies.txt LOCALLY" Chrome extension
#   - Download the cookies.txt file and upload to your server
#   - Set: YTDLP_COOKIES_FILE=/absolute/path/to/cookies.txt
#
# Option 2: For serverless (Vercel/Render), encode cookies as base64
#   - Set: YTDLP_COOKIES_CONTENT=base64:BASE64_ENCODED_CONTENT
#   - Or paste raw cookies.txt content directly
#
# Without cookies, YouTube extraction will fail with bot detection blocks.
# YTDLP_COOKIES_FILE=/absolute/path/to/youtube-cookies.txt
# YTDLP_COOKIES_CONTENT=

# ── Cobalt API Fallback ──────────────────────────────────────────
# If yt-dlp fails (e.g., YouTube blocks the IP), fallback to Cobalt API.
# 
# Self-host a free Cobalt instance:
#   - Deploy on Railway: https://railway.app/ (free tier available)
#   - Cobalt repo: https://github.com/imputnet/cobalt
#   - Then set the deployed URL here:
#
# COBALT_API_URL=https://your-cobalt-instance.up.railway.app

