# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Redis ─────────────────────────────────────────────────────────
# Local:  redis://localhost:6379
# Render: use the Internal Redis URL provided by Render
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────
# Your frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=900000

# ── yt-dlp / YouTube ──────────────────────────────────────────────
# YouTube now requires cookie auth to bypass bot detection.
# Export cookies from a logged-in browser using a tool like "Get cookies.txt LOCALLY"
# (Chrome extension) and save to a path accessible by this server.
# YTDLP_COOKIES_FILE=/absolute/path/to/youtube-cookies.txt

# Alternative for Serverless (Vercel/Render): 
# Paste the RAW content (or base64:ENCODED_CONTENT) of your cookies.txt file here.
# The server will automatically write it to a temp file and use it.
# YTDLP_COOKIES_CONTENT=
