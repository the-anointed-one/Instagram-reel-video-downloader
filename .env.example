# ─── Server ───────────────────────────────────────────────────────
PORT=3001

# ─── MongoDB ──────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/instagram_reels
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/instagram_reels
MONGO_URI=mongodb://localhost:27017/instagram_reels

# ─── yt-dlp ───────────────────────────────────────────────────────
# Path to yt-dlp binary (e.g. /opt/homebrew/bin/yt-dlp on Mac)
YTDLP_PATH=yt-dlp

# ─── Downloads ────────────────────────────────────────────────────
# Directory where downloaded .mp4 files will be saved
DOWNLOAD_DIR=./downloads

# ─── Frontend (Vite) ──────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
